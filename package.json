{
  "name": "esp32-copilot",
  "displayName": "esp32-copilot",
  "description": "AI-powered ESP32 development for VS Code, by Sham",
  "publisher": "sham",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "esp32-copilot.build",
        "title": "ESP32: Build"
      },
      {
        "command": "esp32-copilot.flash",
        "title": "ESP32: Flash"
      },
      {
        "command": "esp32-copilot.monitor",
        "title": "ESP32: Serial Monitor"
      },
      {
        "command": "esp32-copilot.stopMonitor",
        "title": "ESP32: Stop Serial Monitor"
      },
      {
        "command": "esp32-copilot.askAI",
        "title": "ESP32: Ask AI"
      },
      {
        "command": "esp32-copilot.setApiKey",
        "title": "ESP32: Set API Key"
      },
      {
        "command": "esp32-copilot.clearApiKey",
        "title": "ESP32: Clear API Key"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "esp32-copilot-sidebar",
          "title": "ESP32 Copilot",
          "icon": "$(circuit-board)"
        }
      ]
    },
    "views": {
      "esp32-copilot-sidebar": [
        {
          "id": "esp32-copilot.actionsView",
          "name": "Actions",
          "type": "tree"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "undici-types": "^8.1.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1"
  }
}
